# ── Lead form email delivery (optional but recommended for production) ──
# Sign up at https://resend.com, create an API key, verify your sending domain.
# Without these set, form submissions are logged server-side and the user still
# sees a success state (see app/api/quote/route.ts).
RESEND_API_KEY=
LEAD_TO_EMAIL=Office@verticalbc.com
LEAD_FROM_EMAIL=leads@verticalbc.com

